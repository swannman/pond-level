// Copy to secrets.h and fill in your values.
// secrets.h is gitignored — never commit real credentials.
#pragma once

// --- WiFi ----------------------------------------------------------------
#define WIFI_SSID       "your-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

// --- Grafana Cloud (OTLP HTTP metrics push) ------------------------------
// Endpoint for your region. From the Grafana Cloud docs:
//   prod-us-west-0  →  https://prometheus-prod-XX-prod-us-west-0.grafana.net/otlp/v1/metrics
// Replace prod-XX with the cluster shown for your stack at grafana.com.
#define GRAFANA_OTLP_URL     "https://prometheus-prod-XX-prod-us-west-0.grafana.net/otlp/v1/metrics"

// Basic auth: instance_id is the Prometheus instance ID (numeric); api_token
// is a Grafana Cloud Access Policy token (glc_…) with metrics:write scope.
// Get the instance ID at: https://grafana.com/orgs/<your-org>/stacks (look
// for "Prometheus" → "User").
#define GRAFANA_INSTANCE_ID  "0000000"
#define GRAFANA_API_TOKEN    "glc_replaceme"

// --- OTA -----------------------------------------------------------------
// Password required to push firmware over WiFi (sealed enclosure, no USB).
#define OTA_PASSWORD         "change-me"
